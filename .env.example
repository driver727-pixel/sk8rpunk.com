# Environment variables for Skater-Punk

# URL of the Skater-Punk Deck Builder app.
# Cards and decks exported from there can be imported into this game.
VITE_DECK_BUILDER_URL=https://punchskater.com

# Future: domain where this game is hosted (fill in once deployed).
# VITE_GAME_URL=https://your-domain.com

# ── Character Bios access codes ──────────────────────────────────────────────
# Passphrase for the admin (you). Gives access to all bios + "copy viewer link".
VITE_ADMIN_PASS=change-me-admin

# Passphrase for the viewer link shared with C. William Perkins.
# Gives read-only bio access with per-character image reveal dropdown.
VITE_VIEWER_PASS=change-me-viewer
