# Environment variables for Sk8r Punk™ / sk8rpunk.com

# Primary URL for Punch Skater™ (punchskater.com).
# Used for hero CTA, game tile links, Joustur Skatur™ teaser CTA,
# and the ?page=joustur-skatur deep-link redirect.
VITE_PUNCHSKATER_URL=https://punchskater.com

# Future: domain where this game is hosted (fill in once deployed).
